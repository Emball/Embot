# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
Winpython64*/

# ── Project tooling (managed externally) ───────────────────────────────────────
.git/
pyproject.toml
uv.lock

# ── Runtime data (never commit) ───────────────────────────────────────────────
logs/
cache/
db/
temp/
*.log
*.db
*.sqlite
*.tmp

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
config/token
config/token.json
config/token.example
token.json
.python-version

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Temp / helper scripts (not part of the bot) ───────────────────────────────
clean_comments.py
check_broken.py
fix_spaces.py

# ── JSON safety net (config/*.json is committed explicitly) ───────────────────
*.json
!config/*.json
