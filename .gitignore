# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
__init__.py

# ── Runtime data (never commit) ───────────────────────────────────────────────
logs/
cache/
db/
temp/
*.log
*.db
*.sqlite
*.tmp

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
config.ini
Winpython64*/
venv/
env/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Config files ARE committed — do not add *.json here ──────────────────────
# config/moderation.json    ← user settings, word lists, rules content
# config/links_config.json  ← link commands
# config/logger_config.json ← logging toggles and channel IDs
# config/version_data.json  ← version history
# _version.py               ← current version string

# Exclude any JSON that ends up outside config/ (e.g. temp exports)
*.json
!config/*.json
